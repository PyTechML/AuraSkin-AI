# Safe template for local dev. Copy to backend/.env and frontend/web/.env.local, then add secrets.
# Only non-sensitive defaults appear below — never commit real keys or passwords.

# --- Frontend (Next.js) — see frontend/web/.env.example for Vercel / assistant env notes ---
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Backend: Supabase (fill in Dashboard → API; do not commit real values) ---
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Backend: Stripe ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Backend: auth / DB ---
JWT_SECRET=
DATABASE_URL=

# --- AI (OPENAI_API_KEY placeholder matches common setup; replace with your key locally) ---
AI_API_KEY=
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o-mini

# --- Server (from backend/.env — safe local defaults) ---
PORT=3001
NODE_ENV=development
# Match your deployed web origin in production (see backend/.env.example).
CORS_ORIGIN=http://localhost:3000

# --- Optional ---
REDIS_URL=
AI_ENGINE_URL=http://127.0.0.1:8000
INTERNAL_EVENTS_SECRET=
# Questionnaire-only assessment (no face scan); see backend/.env.example and frontend/web/.env.example
ENABLE_QUESTIONNAIRE_ONLY_ASSESSMENT=true
NEXT_PUBLIC_ENABLE_QUESTIONNAIRE_ONLY_ASSESSMENT=true

# --- Monitoring ---
SENTRY_DSN=
LOG_AGGREGATOR_URL=

# --- Seed users (set only in local backend/.env; leave empty here) ---
SEED_USER_PASSWORD=
SEED_STORE_PASSWORD=
SEED_DERMATOLOGIST_PASSWORD=
SEED_MASTER_ADMIN_PASSWORD=
