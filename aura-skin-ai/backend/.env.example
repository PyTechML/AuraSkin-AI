# Copy to .env and fill in real values. Do not commit .env.

# Server
PORT=3001
NODE_ENV=development

# CORS: set to your deployed Next.js origin in production (e.g. https://your-app.vercel.app).
# If unset, main.ts uses a permissive default — prefer an explicit origin for external testers.
CORS_ORIGIN=http://localhost:3000

# Supabase (Dashboard → API)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optional: scripts (e.g. apply-supabase-sql) — never commit real connection strings
SUPABASE_STORAGE_CONNECTION_STRING=

# OpenAI (use AI_API_KEY or OPENAI_API_KEY)
AI_API_KEY=
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o-mini

# Rate limiting / queue (optional)
REDIS_URL=redis://localhost:6379

# AI Engine microservice (optional)
AI_ENGINE_URL=http://localhost:8000

# Public API: merge legacy `stores` table into GET /stores (deduped). Off by default.
# PUBLIC_MERGE_LEGACY_STORES=true
# Append legacy rows only when no partner store_profiles are returned.
# PUBLIC_LEGACY_STORES_WHEN_EMPTY=true

# Allow POST /user/assessment/submit-questionnaire (no face scan). Set false in production to disable.
# Unset: enabled in development, disabled in production (NODE_ENV=production).
ENABLE_QUESTIONNAIRE_ONLY_ASSESSMENT=true

# Stripe (optional; required for payments)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Optional ops
INTERNAL_EVENTS_SECRET=
SENTRY_DSN=
LOG_AGGREGATOR_URL=

# WebRTC (optional; consultation)
STUN_SERVER_URL=stun:stun.l.google.com:19302
TURN_SERVER_URL=
TURN_USERNAME=
TURN_PASSWORD=

# Placeholders if you add later
JWT_SECRET=
DATABASE_URL=

# Auth add-on (defaults off; enable only when ready)
# AUTH_EMAIL_OTP_REQUIRED=true requires AUTH_OTP_ENCRYPTION_KEY, INTERNAL_OTP_BRIDGE_SECRET, and email transport:
#   either RESEND_API_KEY + RESEND_FROM_EMAIL, OR SMTP_HOST + SMTP_FROM + SMTP_USER + SMTP_PASS (SMTP takes priority if SMTP_HOST is set).
AUTH_EMAIL_OTP_REQUIRED=false
AUTH_GMAIL_ONLY=false
# When AUTH_GMAIL_ONLY=true, Apple OAuth is hidden/blocked unless this is true (Hide My Email / iCloud are not @gmail.com)
AUTH_APPLE_OAUTH_WHEN_GMAIL_ONLY=false
# 32-byte key: 64 hex chars OR base64 (used for AES-GCM of pending passwords and Supabase refresh tokens in OTP challenges)
AUTH_OTP_ENCRYPTION_KEY=
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@yourdomain.com
# Nodemailer / SMTP (optional alternative to Resend for OTP mail)
SMTP_HOST=
SMTP_PORT=587
# Set true for port 465 (implicit TLS)
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@yourdomain.com
# Shared secret for Next.js server → Nest POST /auth/oauth-otp/start (OAuth + OTP flow)
INTERNAL_OTP_BRIDGE_SECRET=

# Seed accounts (npm run seed:accounts only — set in local .env only)
SEED_USER_PASSWORD=
SEED_STORE_PASSWORD=
SEED_DERMATOLOGIST_PASSWORD=
SEED_MASTER_ADMIN_PASSWORD=
