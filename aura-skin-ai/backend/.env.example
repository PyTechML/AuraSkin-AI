# Copy to .env and fill in real values. Do not commit .env.

# Server
PORT=3001
NODE_ENV=development

# CORS: set to your deployed Next.js origin in production (e.g. https://your-app.vercel.app).
# If unset, main.ts uses a permissive default — prefer an explicit origin for external testers.
CORS_ORIGIN=http://localhost:3000

# Supabase (Dashboard → API)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optional: scripts (e.g. apply-supabase-sql) — never commit real connection strings
SUPABASE_STORAGE_CONNECTION_STRING=

# OpenAI (use AI_API_KEY or OPENAI_API_KEY)
AI_API_KEY=
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o-mini

# Rate limiting / queue (optional)
REDIS_URL=redis://localhost:6379

# AI Engine microservice (optional)
AI_ENGINE_URL=http://localhost:8000

# Allow POST /user/assessment/submit-questionnaire (no face scan). Set false in production to disable.
# Unset: enabled in development, disabled in production (NODE_ENV=production).
ENABLE_QUESTIONNAIRE_ONLY_ASSESSMENT=true

# Stripe (optional; required for payments)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Optional ops
INTERNAL_EVENTS_SECRET=
SENTRY_DSN=
LOG_AGGREGATOR_URL=

# WebRTC (optional; consultation)
STUN_SERVER_URL=stun:stun.l.google.com:19302
TURN_SERVER_URL=
TURN_USERNAME=
TURN_PASSWORD=

# Placeholders if you add later
JWT_SECRET=
DATABASE_URL=

# Seed accounts (npm run seed:accounts only — set in local .env only)
SEED_USER_PASSWORD=
SEED_STORE_PASSWORD=
SEED_DERMATOLOGIST_PASSWORD=
SEED_MASTER_ADMIN_PASSWORD=
