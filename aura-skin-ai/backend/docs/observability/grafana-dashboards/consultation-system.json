        { "expr": "consultation_sessions_active", "legendFormat": "Active sessions" },
        { "expr": "websocket_connections_active", "legendFormat": "WebSocket connections" }
      ],
      "title": "Active consultation sessions",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "unit": "s", "color": { "mode": "palette-classic" } },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "id": 2,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        { "expr": "histogram_quantile(0.50, sum(rate(consultation_session_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p50 duration" },
        { "expr": "histogram_quantile(0.95, sum(rate(consultation_session_duration_seconds_bucket[5m])) by (le))", "legendFormat": "p95 duration" }
      ],
      "title": "Consultation session duration",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "fieldConfig": {
        "defaults": { "color": { "mode": "palette-classic" } },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "id": 3,
      "options": { "legend": { "displayMode": "list", "placement": "bottom" } },
      "targets": [
        { "expr": "rate(consultation_connection_failures_total[5m])", "legendFormat": "Connection failures/sec" }
      ],
      "title": "Consultation connection failures",
      "type": "timeseries"
    }
  ],
