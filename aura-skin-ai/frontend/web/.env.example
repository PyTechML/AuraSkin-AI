# Copy to .env.local for local dev. On Vercel: Project → Settings → Environment Variables.

# --- Required in production ---
# HTTPS URL of your deployed Nest API (no trailing slash). If unset at build time, the app falls back to
# http://localhost:3001, which breaks external testers — always set this on Vercel.
NEXT_PUBLIC_API_URL=http://localhost:3001

# Supabase (Dashboard → Project Settings → API). URL + anon key MUST be from the same project.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
#
# Social sign-in: if you see "provider is not enabled", open Supabase → Authentication → Providers
# and enable Google and/or Apple with OAuth client ID + secret (Google Cloud / Apple Developer).
# In Google Cloud, set Authorized redirect URI to: https://<project-ref>.supabase.co/auth/v1/callback
# In Supabase → Authentication → URL Configuration, add Redirect URLs for this app, e.g.:
#   http://localhost:3000/api/auth/callback   (local Next port)
#   https://<your-production-domain>/api/auth/callback

# Show "Continue without face scan" on Step 6. Set to false to hide (should match backend flag in production).
NEXT_PUBLIC_ENABLE_QUESTIONNAIRE_ONLY_ASSESSMENT=true

# Auth UI add-on (must mirror backend flags in production; server still enforces)
NEXT_PUBLIC_AUTH_EMAIL_OTP_REQUIRED=false
NEXT_PUBLIC_AUTH_GMAIL_ONLY=false
NEXT_PUBLIC_AUTH_APPLE_OAUTH_WHEN_GMAIL_ONLY=false
# Same value as backend INTERNAL_OTP_BRIDGE_SECRET — used only by Next Route Handlers (server), never exposed to browser
INTERNAL_OTP_BRIDGE_SECRET=

# Server-only OAuth callback (mirror backend; used by src/app/api/auth/callback/route.ts)
AUTH_EMAIL_OTP_REQUIRED=false
AUTH_GMAIL_ONLY=false
AUTH_APPLE_OAUTH_WHEN_GMAIL_ONLY=false

# --- Vercel / Next.js server-only (do NOT use NEXT_PUBLIC_* for these) ---
# Used by App Router route handlers under /api/assistant (OpenAI runs on the server, not in the bundle).
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
